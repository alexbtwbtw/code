# Copy this file to .env and fill in your values
#
#   cp .env.example .env

# ── Anthropic API ──────────────────────────────────────────────────────────────
# Required for CV parsing (team member import) and requirements import from PDF/Word.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the Hono backend listens on (default: 3000)
# PORT=3000

# ── Electron / production static serving ──────────────────────────────────────
# Set automatically by the Electron main process — no need to set manually.
# SERVE_STATIC=true
# STATIC_ROOT=/path/to/frontend/dist
